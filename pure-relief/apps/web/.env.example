# Copy to .env.local for local development against a running `wrangler dev` worker.
# Leave VITE_API_BASE_URL empty in production if the worker is served on the same
# domain as the frontend (recommended: use a Cloudflare Pages _redirects rule or
# a single Worker that serves both). Set it to the full worker URL otherwise.
VITE_API_BASE_URL=http://127.0.0.1:8787
VITE_PUBLIC_SITE_URL=https://purerelief.co.uk
