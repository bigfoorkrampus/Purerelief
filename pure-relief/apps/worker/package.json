{
  "name": "@pure-relief/worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply pure_relief_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply pure_relief_db --remote",
    "db:seed:local": "wrangler d1 execute pure_relief_db --local --file=./seed.sql",
    "db:seed:remote": "wrangler d1 execute pure_relief_db --remote --file=./seed.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pure-relief/shared": "*",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.99.0"
  }
}
